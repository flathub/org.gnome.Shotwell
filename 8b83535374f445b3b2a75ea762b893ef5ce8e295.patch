From 51dd922e7c257e256c526116156b251e36852da4 Mon Sep 17 00:00:00 2001
From: Sophie Herold <sophie@hemio.de>
Date: Wed, 13 May 2026 20:23:42 +0200
Subject: [PATCH] glycin-utils: Save new images via fwrite

Looking up the filename gave issues with the kernel attaching
" (deleted)" to the path when using the document portal.

Fixes #295
---
 gdk-pixbuf/io-glycin-utils.c | 31 +++++++++++++++++++------------
 1 file changed, 19 insertions(+), 12 deletions(-)

diff --git a/gdk-pixbuf/io-glycin-utils.c b/gdk-pixbuf/io-glycin-utils.c
index 12d82d9a0..2b44a0e25 100644
--- a/gdk-pixbuf/io-glycin-utils.c
+++ b/gdk-pixbuf/io-glycin-utils.c
@@ -800,21 +800,28 @@ glycin_image_save (const char         *mimetype,
 
   if (f)
     {
-      GFile *file = g_file_from_file (f, error);
+      size_t n_written;
 
-      if (!file)
-        res = FALSE;
+      while (length > 0)
+        {
+          n_written = fwrite (image_data, sizeof (gchar), length, f);
+          if (n_written <= 0)
+            break;
+          length -= n_written;
+          image_data += n_written;
+        }
+
+      if (length)
+        {
+          g_set_error_literal (error,
+                          GDK_PIXBUF_ERROR,
+                          GDK_PIXBUF_ERROR_FAILED,
+                          "Couldn't write to file");
+          res = FALSE;
+        }
       else
         {
-          res = g_file_replace_contents (file,
-                                         image_data, length,
-                                         NULL,
-                                         FALSE,
-                                         G_FILE_CREATE_NONE,
-                                         NULL,
-                                         NULL,
-                                         error);
-          g_object_unref (file);
+          res = TRUE;
         }
     }
   else
